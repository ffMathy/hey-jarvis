{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "GITHUB_ACTIONS",
    "GITHUB_TOKEN",
    "GITHUB_ACTOR",
    "IMAGE_TAG",
    "IMAGE_OWNER",
    "REGISTRY",
    "TURBO_TOKEN",
    "TURBO_TEAM",
    "WORKSPACE_ROOT",
    "HEY_JARVIS_ALGOLIA_API_KEY",
    "HEY_JARVIS_ALGOLIA_APPLICATION_ID",
    "HEY_JARVIS_BILKA_API_KEY",
    "HEY_JARVIS_BILKA_EMAIL",
    "HEY_JARVIS_BILKA_PASSWORD",
    "HEY_JARVIS_BILKA_USER_TOKEN",
    "HEY_JARVIS_CLOUDFLARED_TUNNEL_TOKEN",
    "HEY_JARVIS_CLOUDFLARED_TUNNEL_URL",
    "HEY_JARVIS_ELEVENLABS_AGENT_ID",
    "HEY_JARVIS_ELEVENLABS_API_KEY",
    "HEY_JARVIS_ELEVENLABS_TEST_AGENT_ID",
    "HEY_JARVIS_ELEVENLABS_VOICE_ID",
    "HEY_JARVIS_GITHUB_API_TOKEN",
    "HEY_JARVIS_GOOGLE_API_KEY",
    "HEY_JARVIS_GOOGLE_CLIENT_ID",
    "HEY_JARVIS_GOOGLE_CLIENT_SECRET",
    "HEY_JARVIS_GOOGLE_GENERATIVE_AI_API_KEY",
    "HEY_JARVIS_GOOGLE_REFRESH_TOKEN",
    "HEY_JARVIS_HOME_ASSISTANT_TOKEN",
    "HEY_JARVIS_HOME_ASSISTANT_URL",
    "HEY_JARVIS_MEAL_PLAN_NOTIFICATION_EMAIL",
    "HEY_JARVIS_MICROSOFT_CLIENT_ID",
    "HEY_JARVIS_MICROSOFT_CLIENT_SECRET",
    "HEY_JARVIS_MICROSOFT_REFRESH_TOKEN",
    "HEY_JARVIS_OPENWEATHERMAP_API_KEY",
    "HEY_JARVIS_TAVILY_API_KEY",
    "HEY_JARVIS_TWILIO_ACCOUNT_SID",
    "HEY_JARVIS_TWILIO_AUTH_TOKEN",
    "HEY_JARVIS_TWILIO_PHONE_NUMBER",
    "HEY_JARVIS_VALDEMARSRO_API_KEY",
    "HEY_JARVIS_WIFI_PASSWORD",
    "HEY_JARVIS_WIFI_SSID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "lint", "typecheck", "initialize"],
      "outputs": ["../dist/**", ".esphome/build/**"]
    },
    "typecheck": {
      "inputs": ["**/*.ts", "**/*.tsx", "tsconfig*.json"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["typecheck"],
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.json", "$TURBO_ROOT/biome.json"],
      "cache": true
    },
    "format": {
      "cache": false
    },
    "test": {
      "dependsOn": ["lint"],
      "outputs": ["../coverage/**"]
    },
    "deploy": {
      "dependsOn": ["build"]
    },
    "serve": {
      "cache": false,
      "persistent": true
    },
    "e2e": {
      "dependsOn": ["build"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "initialize": {
      "cache": true
    }
  }
}
