{
  "name": "elevenlabs",
  "version": "0.11.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsgo --noEmit --project tsconfig.json",
    "lint": "cd .. && bunx biome check --write elevenlabs",
    "format": "cd .. && bunx biome format --write elevenlabs",
    "build": ".scripts/build.sh",
    "deploy": "cd .. && ./.scripts/run-with-env.sh elevenlabs/op.env bun elevenlabs/src/main.ts deploy",
    "deploy:test": "cd .. && ./.scripts/run-with-env.sh elevenlabs/op.env bun elevenlabs/src/main.ts deploy --test",
    "refresh": "cd .. && ./.scripts/run-with-env.sh elevenlabs/op.env bun elevenlabs/src/main.ts fetch",
    "test": "cd .. && ./.scripts/run-with-env.sh elevenlabs/op.env elevenlabs/.scripts/test.sh",
    "tunnel": "cd .. && ./.scripts/run-with-env.sh elevenlabs/op.env bun elevenlabs/tests/utils/tunnel-manager.ts",
    "initialize": "cd .. && bunx playwright install && bunx playwright install-deps",
    "env:local": "cd .. && ./.scripts/generate-env-local.sh elevenlabs/op.env"
  },
  "devDependencies": {
    "bun-types": "1.3.10"
  }
}
